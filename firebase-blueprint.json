{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email"]
    },
    "EventType": {
      "title": "EventType",
      "description": "Configurable categories for events",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "name", "color", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "A calendar event",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "eventTypeId": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "allDay": { "type": "boolean" },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "reminderMinutesBefore": { "type": "number" },
        "repeatRule": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "title", "eventTypeId", "startTime", "endTime", "allDay", "createdAt", "updatedAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A standalone task or reminder",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "dueTime": { "type": "string" },
        "notes": { "type": "string" },
        "repeatRule": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "completed", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/eventTypes/{typeId}": {
      "schema": { "$ref": "#/entities/EventType" },
      "description": "User custom event types"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "User events"
    },
    "/reminders/{reminderId}": {
      "schema": { "$ref": "#/entities/Reminder" },
      "description": "User reminders"
    }
  }
}
